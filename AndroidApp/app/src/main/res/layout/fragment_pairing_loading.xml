<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_blue_light">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardPairing"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:cardCornerRadius="24dp"
        app:cardElevation="6dp"
        app:cardBackgroundColor="@color/card_white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="28dp"
            android:gravity="center">

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đang kết nối với xe"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="4dp"/>

            <!-- Device name -->
            <TextView
                android:id="@+id/tvDeviceName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="36dp"/>

            <!-- Road track — car animates inside this -->
            <FrameLayout
                android:id="@+id/roadTrack"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:clipChildren="true"
                android:layout_marginBottom="28dp">

                <!-- Road surface -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="5dp"
                    android:layout_gravity="bottom"
                    android:layout_marginBottom="8dp"
                    android:background="#CFD8DC"/>

                <!-- Dashed center divider (simple block) -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:layout_gravity="bottom"
                    android:layout_marginBottom="22dp"
                    android:background="#E0E0E0"/>

                <!-- Car — translated by ObjectAnimator in code -->
                <ImageView
                    android:id="@+id/ivCar"
                    android:layout_width="72dp"
                    android:layout_height="44dp"
                    android:layout_gravity="bottom|start"
                    android:layout_marginBottom="13dp"
                    android:src="@drawable/car_icon"
                    android:scaleType="fitCenter"/>

            </FrameLayout>

            <!-- Step status text -->
            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đang khởi động..."
                android:textSize="15sp"
                android:textColor="#1976D2"
                android:gravity="center"
                android:layout_marginBottom="32dp"/>

            <!-- Cancel button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancel"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hủy"
                android:textColor="#1976D2"
                app:strokeColor="#1976D2"
                app:strokeWidth="1dp"/>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
